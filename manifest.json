{
  "manifest_version": 3,
  "name": "GAS Trigger",
  "version": "1.0.0",
  "description": "Trigger Google Apps Script Web Apps from your browser toolbar",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "src/popup/index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "https://script.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.atlassian.net/*"
  ]
}
